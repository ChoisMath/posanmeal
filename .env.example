# Database
DATABASE_URL="postgresql://posanmeal:posanmeal@localhost:5432/posanmeal"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Public site URL — used for absolute URLs in OG/Twitter metadata.
# prod (main):       https://meal.posan.kr
# test (feat/...):   https://posanmeal.up.railway.app
NEXT_PUBLIC_SITE_URL="https://meal.posan.kr"

# Admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="$2a$10$..."

# QR Token
QR_JWT_SECRET="generate-a-random-secret"
QR_TOKEN_EXPIRY_SECONDS=180

# File Upload
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE_MB=5

# Timezone
TZ="Asia/Seoul"
